{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "hugo --gc --minify && npx -y pagefind --site public",
  "outputDirectory": "public",
  "framework": "hugo",
  "cleanUrls": true,
  "trailingSlash": true,

  "redirects": [
    {
      "source": "/tags/%E9%96%B1%E8%AE%80%E6%9B%B8%E6%91%98/",
      "destination": "/tags/%E6%9B%B8%E6%91%98/",
      "permanent": true
    },
    {
      "source": "/categories/%E9%96%B1%E8%AE%80%E6%9B%B8%E6%91%98/:path*/",
      "destination": "/categories/%E6%9B%B8%E6%91%98/:path*/",
      "permanent": true
    },
    {
      "source": "/:path*.html",
      "destination": "/:path*/",
      "permanent": true
    }
  ],

  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/ui/:path*", "destination": "/api/ui/:path*" }
  ],

  "headers": [
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
